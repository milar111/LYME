# ══════════════════════════════════════════════════════════════════════════════
# LYME Project — .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ── Python: Byte-compiled / optimized / DLL files ────────────────────────────
__pycache__/
*.py[codz]
*$py.class

# ── Python: C extensions ─────────────────────────────────────────────────────
*.so

# ── Python: Distribution / packaging ─────────────────────────────────────────
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ── Python: PyInstaller ──────────────────────────────────────────────────────
*.manifest
*.spec

# ── Python: Installer logs ───────────────────────────────────────────────────
pip-log.txt
pip-delete-this-directory.txt

# ── Python: Unit test / coverage reports ─────────────────────────────────────
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py.cover
.hypothesis/
.pytest_cache/
cover/

# ── Python: Translations ────────────────────────────────────────────────────
*.mo
*.pot

# ── Python: Django / Flask ───────────────────────────────────────────────────
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
instance/
.webassets-cache

# ── Python: Scrapy ───────────────────────────────────────────────────────────
.scrapy

# ── Python: Sphinx documentation ────────────────────────────────────────────
docs/_build/

# ── Python: PyBuilder ────────────────────────────────────────────────────────
.pybuilder/
target/

# ── Python: Jupyter / IPython ────────────────────────────────────────────────
.ipynb_checkpoints
profile_default/
ipython_config.py

# ── Python: Environments ─────────────────────────────────────────────────────
.env
.envrc
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# ── Python: Package managers (pipenv, pdm, poetry, uv, pixi) ────────────────
.pdm-python
.pdm-build/
.pixi
__pypackages__/

# ── Python: Celery ───────────────────────────────────────────────────────────
celerybeat-schedule
celerybeat.pid

# ── Python: Redis / RabbitMQ / ActiveMQ ──────────────────────────────────────
*.rdb
*.aof
*.pid
mnesia/
rabbitmq/
rabbitmq-data/
activemq-data/

# ── Python: SageMath ─────────────────────────────────────────────────────────
*.sage.py

# ── Python: Type checkers (mypy, pyre, pytype) ──────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# ── Python: Cython debug symbols ────────────────────────────────────────────
cython_debug/

# ── Python: Ruff / PyPI ──────────────────────────────────────────────────────
.ruff_cache/
.pypirc

# ── Python: Marimo / Streamlit ───────────────────────────────────────────────
marimo/_static/
marimo/_lsp/
__marimo__/
.streamlit/secrets.toml

# ── Python: Abstra ───────────────────────────────────────────────────────────
.abstra/

# ══════════════════════════════════════════════════════════════════════════════
# LYME: Project-specific ignores
# ══════════════════════════════════════════════════════════════════════════════

# ── LYME: Runtime data (snapshots, logs, model flags) ────────────────────────
data/logs.txt
data/snapshots/
data/.model_initialized
data/test_*.jpg
data/test_*.png
# Keep zone.json and context.json — they store user configuration

# ── LYME: AI model weights (large binaries — download on first run) ──────────
*.tflite
*.task

# ── LYME: Dev / test / scratch scripts ───────────────────────────────────────
test.py
test_*.py
test_*.sh
run.sh

# ── LYME: Docker / containerisation test docs ────────────────────────────────
docs/containerisation*
docs/docker_testing*
container_test*
CONTAINER_TESTS*


# ══════════════════════════════════════════════════════════════════════════════
# IDE / Editor / OS
# ══════════════════════════════════════════════════════════════════════════════

# ── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/

# ── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# ── AI assistant / agent directories ─────────────────────────────────────────
.gemini/
.agents/
.agent/
_agents/
_agent/
